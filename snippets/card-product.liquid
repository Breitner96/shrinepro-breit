{% comment %}
  AURA Product Card — Redesigned
{% endcomment %}

{{ 'aura-collection.css' | asset_url | stylesheet_tag }}

{%- if card_product and card_product != empty -%}
  {%- liquid
    assign has_secondary = false
    if card_product.media[1] != null and show_secondary_image
      assign has_secondary = true
    endif

    assign is_sale = false
    if card_product.compare_at_price > card_product.price and card_product.available
      assign is_sale = true
    endif

    assign is_new = false
    assign days_old = 'now' | date: '%s' | minus: card_product.published_at | date: '%s' | divided_by: 86400
    if days_old < 30
      assign is_new = true
    endif
  -%}

  <a href="{{ card_product.url }}" class="aura-card" aria-label="{{ card_product.title | escape }}">

    <div class="aura-card__media">

      {%- if card_product.featured_media -%}
        <img
          class="aura-card__img aura-card__img--primary{% unless has_secondary %} is-only{% endunless %}"
          src="{{ card_product.featured_media | image_url: width: 600 }}"
          srcset="
            {{ card_product.featured_media | image_url: width: 360 }} 360w,
            {{ card_product.featured_media | image_url: width: 600 }} 600w,
            {{ card_product.featured_media | image_url: width: 900 }} 900w
          "
          sizes="(min-width: 990px) 33vw, (min-width: 750px) 50vw, 50vw"
          alt="{{ card_product.featured_media.alt | escape }}"
          {% unless lazy_load == false %}loading="lazy"{% endunless %}
          width="{{ card_product.featured_media.width }}"
          height="{{ card_product.featured_media.height }}"
        >
      {%- endif -%}

      {%- if has_secondary -%}
        <img
          class="aura-card__img aura-card__img--secondary"
          src="{{ card_product.media[1] | image_url: width: 600 }}"
          srcset="
            {{ card_product.media[1] | image_url: width: 360 }} 360w,
            {{ card_product.media[1] | image_url: width: 600 }} 600w,
            {{ card_product.media[1] | image_url: width: 900 }} 900w
          "
          sizes="(min-width: 990px) 33vw, (min-width: 750px) 50vw, 50vw"
          alt=""
          loading="lazy"
          width="{{ card_product.media[1].width }}"
          height="{{ card_product.media[1].height }}"
        >
      {%- endif -%}

      {%- if card_product.available == false -%}
        <span class="aura-card__badge aura-card__badge--sold-out">Agotado</span>
      {%- elsif is_sale -%}
        <span class="aura-card__badge aura-card__badge--sale">2x1 Oferta</span>
      {%- elsif is_new -%}
        <span class="aura-card__badge aura-card__badge--new">Nuevo</span>
      {%- endif -%}

      <div class="aura-card__overlay">Ver producto →</div>

    </div>

    <div class="aura-card__info">
      <div class="aura-card__name">{{ card_product.title | escape }}</div>

      <div class="aura-card__stars">
        <span class="aura-card__stars-icons">★★★★★</span>
        <span class="aura-card__stars-score">4.8</span>
      </div>

      <div class="aura-card__price-row">
        {%- if is_sale -%}
          <span class="aura-card__price aura-card__price--sale">{{ card_product.price | money_without_trailing_zeros }}</span>
          <span class="aura-card__price aura-card__price--compare">{{ card_product.compare_at_price | money_without_trailing_zeros }}</span>
        {%- else -%}
          <span class="aura-card__price">{{ card_product.price | money_without_trailing_zeros }}</span>
        {%- endif -%}
      </div>

      <span class="aura-card__shipping">✓ Envío GRATIS</span>
    </div>

  </a>

{%- else -%}
  <div class="aura-card">
    <div class="aura-card__media" style="background:#f4f4f4; aspect-ratio:1;"></div>
    <div class="aura-card__info">
      <div class="aura-card__name">Producto</div>
      <div class="aura-card__price-row">
        <span class="aura-card__price">$0</span>
      </div>
    </div>
  </div>
{%- endif -%}
