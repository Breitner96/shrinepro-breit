<div class="aura-benefits" style="background-color: {{ block.settings.checkmarkcolorbackground }};">
  {%- if block.settings.key1 != blank -%}
  <div class="aura-benefit-item">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.checkmarkcolor | default: '#0A0A0A' }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    <span>{{ block.settings.key1 }}</span>
  </div>
  {%- endif -%}
  {%- if block.settings.key2 != blank -%}
  <div class="aura-benefit-item">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.checkmarkcolor | default: '#0A0A0A' }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    <span>{{ block.settings.key2 }}</span>
  </div>
  {%- endif -%}
  {%- if block.settings.key3 != blank -%}
  <div class="aura-benefit-item">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.checkmarkcolor | default: '#0A0A0A' }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
    <span>{{ block.settings.key3 }}</span>
  </div>
  {%- endif -%}
</div>

<style>
.aura-benefits {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 16px;
  border-radius: 0;
  margin: 4px 0;
}
.aura-benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 1.4rem;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}
.aura-benefit-item svg {
  flex-shrink: 0;
  margin-top: 2px;
}
</style>
