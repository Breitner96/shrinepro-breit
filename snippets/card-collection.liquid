{% comment %}
  AURA Collection Card — Redesigned
{% endcomment %}

<a href="{{ card_collection.url }}" class="aura-col-card">
  <div class="aura-col-card__media">
    {%- if card_collection.featured_image -%}
      <img
        src="{{ card_collection.featured_image | image_url: width: 800 }}"
        srcset="
          {{ card_collection.featured_image | image_url: width: 400 }} 400w,
          {{ card_collection.featured_image | image_url: width: 800 }} 800w,
          {{ card_collection.featured_image | image_url: width: 1200 }} 1200w
        "
        sizes="(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw"
        alt="{{ card_collection.title | escape }}"
        loading="lazy"
        class="aura-col-card__img"
      >
    {%- else -%}
      <div class="aura-col-card__placeholder"></div>
    {%- endif -%}

    <div class="aura-col-card__overlay"></div>

    <div class="aura-col-card__info">
      <h3 class="aura-col-card__title">{{ card_collection.title | escape }}</h3>
      {%- if card_collection.all_products_count > 0 -%}
        <span class="aura-col-card__count">{{ card_collection.all_products_count }} productos</span>
      {%- endif -%}
    </div>

    <div class="aura-col-card__cta">Ver colección →</div>
  </div>
</a>
