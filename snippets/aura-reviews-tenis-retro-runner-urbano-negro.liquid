<script>
(function() {
  var track = document.getElementById('auraReviewsTrack-tenis-retro-runner-urbano-negro');
  var dots  = document.querySelectorAll('#auraReviewsDots-tenis-retro-runner-urbano-negro .aura-reviews__dot');
  if (!track || !dots.length) return;
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var card = track.children[parseInt(this.getAttribute('data-index'))];
      if (card) track.scrollTo({ left: card.offsetLeft - 4, behavior: 'smooth' });
    });
  });
  track.addEventListener('scroll', function() {
    var w = track.children[0] ? track.children[0].offsetWidth + 12 : 1;
    var idx = Math.round(track.scrollLeft / w);
    dots.forEach(function(d, i) { d.classList.toggle('aura-reviews__dot--active', i === idx); });
  }, { passive: true });
})();
</script>