        "custom_liquid_iWDE9T": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"size-guide-trigger-container\">\n  <p class=\"size-guide-note\">\n    📏 <strong>Importante:</strong> revisa la <strong>guía de tallas</strong> antes de comprar para elegir tu talla correcta.\n  </p>\n\n  <button type=\"button\" class=\"size-guide-button\" id=\"openSizeGuide\">\n    <span class=\"icon-ruler\"></span> Guía de tallas\n  </button>\n</div>\n\n<div id=\"sizeGuideModal\" class=\"size-modal\" aria-hidden=\"true\">\n  <div class=\"size-modal-content\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Guía de tallas\">\n    <div class=\"size-modal-header\">\n      <h3 class=\"size-modal-title\">Guía de tallas</h3>\n      <button type=\"button\" class=\"close-size-modal\" id=\"closeSizeGuide\" aria-label=\"Cerrar\">&times;</button>\n    </div>\n\n    <div class=\"size-modal-body\">\n      <img\n        src=\"https://cdn.shopify.com/s/files/1/0983/0213/2505/files/tabla_tallas_Tiger.png?v=1774656807\"\n        alt=\"Guía de tallas\"\n        loading=\"lazy\"\n      >\n    </div>\n  </div>\n</div>\n\n<style>\n  /* Contenedor del botón */\n  .size-guide-trigger-container {\n    margin: 10px 0;\n  }\n\n  /* Texto importante */\n  .size-guide-note{\n    margin: 0 0 8px 0;\n    font-size: 1.35rem;\n    line-height: 1.35;\n    color: #1A1A1A;\n    opacity: 0.9;\n  }\n\n  .size-guide-button {\n    background: none;\n    border: none;\n    color: #1A1A1A;\n    text-decoration: underline;\n    font-size: 1.4rem;\n    cursor: pointer;\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 0;\n    font-weight: 600;\n  }\n\n  /* Overlay */\n  .size-modal {\n    display: none;\n    position: fixed;\n    z-index: 9999;\n    left: 0;\n    top: 0;\n    width: 100%;\n    height: 100%;\n    background-color: rgba(0,0,0,0.6);\n    backdrop-filter: blur(3px);\n  }\n\n  /* Contenedor blanco */\n  .size-modal-content {\n    background-color: #fff;\n    margin: 5% auto;\n    padding: 0;\n    width: 90%;\n    max-width: 600px;\n    border-radius: 10px;\n    position: relative;\n    box-shadow: 0 4px 20px rgba(0,0,0,0.2);\n    animation: slideIn 0.25s ease-out;\n    overflow: hidden;\n  }\n\n  @keyframes slideIn {\n    from { transform: translateY(-25px); opacity: 0; }\n    to { transform: translateY(0); opacity: 1; }\n  }\n\n  /* Header modal */\n  .size-modal-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 14px 18px;\n    border-bottom: 1px solid #eee;\n  }\n\n  .size-modal-title{\n    margin: 0;\n    font-size: 1.7rem;\n    color: #1A1A1A;\n    font-weight: 700;\n  }\n\n  .close-size-modal {\n    background: none;\n    border: none;\n    font-size: 3rem;\n    line-height: 1;\n    cursor: pointer;\n    color: #888;\n  }\n\n  /* Body */\n  .size-modal-body {\n    padding: 18px;\n    max-height: 80vh;\n    overflow-y: auto;\n    text-align: center;\n  }\n\n  .size-modal-body img {\n    max-width: 100%;\n    height: auto;\n    border-radius: 6px;\n  }\n\n  /* Móvil */\n  @media (max-width: 480px) {\n    .size-modal-content {\n      margin: 18% auto;\n      width: 95%;\n    }\n    .size-guide-note{\n      font-size: 1.28rem;\n    }\n  }\n</style>\n\n<script>\n  const modal = document.getElementById(\"sizeGuideModal\");\n  const btn = document.getElementById(\"openSizeGuide\");\n  const closeBtn = document.getElementById(\"closeSizeGuide\");\n\n  // Abrir\n  btn.onclick = function() {\n    modal.style.display = \"block\";\n    modal.setAttribute(\"aria-hidden\", \"false\");\n    document.body.style.overflow = \"hidden\";\n  }\n\n  // Cerrar con la X\n  closeBtn.onclick = function() {\n    modal.style.display = \"none\";\n    modal.setAttribute(\"aria-hidden\", \"true\");\n    document.body.style.overflow = \"auto\";\n  }\n\n  // Cerrar haciendo clic fuera\n  window.onclick = function(event) {\n    if (event.target === modal) {\n      modal.style.display = \"none\";\n      modal.setAttribute(\"aria-hidden\", \"true\");\n      document.body.style.overflow = \"auto\";\n    }\n  }\n</script>"
          }
        },
