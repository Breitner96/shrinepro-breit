          "settings": {
            "custom_liquid": "<div class=\"product-verified-wrapper\">\n    <h1 class=\"product-title-inline\">\n        {{ product.title }}\n        <img class=\"inline-check-icon\" src=\"https://cdn-icons-png.flaticon.com/512/1828/1828640.png\" alt=\"Verificado\">\n    </h1>\n</div>\n\n<style>\n    .product-verified-wrapper {\n        margin: 0 0 10px 0 !important; /* Ajusta el espacio con lo que sigue abajo */\n        padding: 0;\n        line-height: 1.2;\n    }\n\n    .product-title-inline {\n        /* Hereda la fuente de tu título de Shopify */\n        font-family: var(--font-heading-family), sans-serif;\n        font-weight: var(--font-heading-weight, bold);\n        font-size: 25px;\n        color: #1A1A1A; /* Tu color negro profundo */\n        \n        /* IMPORTANTE: Permite que el contenido fluya como texto */\n        display: inline; \n        margin: 0;\n        padding: 0;\n        word-wrap: break-word;\n    }\n\n    .inline-check-icon {\n        /* Se comporta como una letra más */\n        display: inline-block;\n        vertical-align: middle; \n        width: 24px; \n        height: 24px;\n        margin-left: 4px; /* Espacio pequeño tras la última palabra */\n        object-fit: contain;\n    }\n\n    /* Ajuste para móviles */\n    @media (max-width: 749px) {\n        .product-title-inline {\n            font-size: 20px;\n        }\n        .inline-check-icon {\n            width: 18px;\n            height: 18px;\n        }\n    }\n</style>"
          }
