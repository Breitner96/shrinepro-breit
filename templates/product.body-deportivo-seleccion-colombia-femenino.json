        "custom_liquid_talla_body": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"size-guide-trigger-container\">\n  <p class=\"size-guide-note\">\n    📏 <strong>Importante:</strong> revisa la <strong>guía de tallas</strong> antes de comprar para elegir tu talla correcta.\n  </p>\n\n  <button type=\"button\" class=\"size-guide-button\" id=\"openSizeGuideBody\">\n    <span class=\"icon-ruler\"></span> Guía de tallas\n  </button>\n</div>\n\n<div id=\"sizeGuideModalBody\" class=\"size-modal\" aria-hidden=\"true\">\n  <div class=\"size-modal-content\" role=\"dialog\" aria-modal=\"true\" aria-label=\"Guía de tallas body\">\n    <div class=\"size-modal-header\">\n      <h3 class=\"size-modal-title\">Guía de tallas — Body</h3>\n      <button type=\"button\" class=\"close-size-modal\" id=\"closeSizeGuideBody\" aria-label=\"Cerrar\">&times;</button>\n    </div>\n\n    <div class=\"size-modal-body\">\n      <table class=\"body-size-table\">\n        <thead>\n          <tr><th>Talla</th><th>Busto (cm)</th><th>Cintura (cm)</th><th>Cadera (cm)</th></tr>\n        </thead>\n        <tbody>\n          <tr><td>S</td><td>82–86</td><td>62–66</td><td>88–92</td></tr>\n          <tr><td>M</td><td>87–91</td><td>67–71</td><td>93–97</td></tr>\n          <tr><td>L</td><td>92–96</td><td>72–76</td><td>98–102</td></tr>\n          <tr><td>XL</td><td>97–102</td><td>77–82</td><td>103–108</td></tr>\n          <tr><td>2XL</td><td>103–109</td><td>83–89</td><td>109–115</td></tr>\n          <tr><td>3XL</td><td>110–117</td><td>90–97</td><td>116–123</td></tr>\n        </tbody>\n      </table>\n      <p style=\"margin-top:12px;font-size:1.3rem;color:#555;\">Si estás entre dos tallas, elige la más grande.</p>\n    </div>\n  </div>\n</div>\n\n<style>\n  .size-guide-trigger-container { margin: 10px 0; }\n  .size-guide-note { margin: 0 0 8px 0; font-size: 1.35rem; line-height: 1.35; color: #1A1A1A; opacity: 0.9; }\n  .size-guide-button { background: none; border: none; color: #1A1A1A; text-decoration: underline; font-size: 1.4rem; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; padding: 0; font-weight: 600; }\n  .size-modal { display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6); backdrop-filter: blur(3px); }\n  .size-modal-content { background-color: #fff; margin: 5% auto; padding: 0; width: 90%; max-width: 560px; border-radius: 10px; position: relative; box-shadow: 0 4px 20px rgba(0,0,0,0.2); animation: slideIn 0.25s ease-out; overflow: hidden; }\n  @keyframes slideIn { from { transform: translateY(-25px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }\n  .size-modal-header { display: flex; justify-content: space-between; align-items: center; padding: 14px 18px; border-bottom: 1px solid #eee; }\n  .size-modal-title { margin: 0; font-size: 1.7rem; color: #1A1A1A; font-weight: 700; }\n  .close-size-modal { background: none; border: none; font-size: 3rem; line-height: 1; cursor: pointer; color: #888; }\n  .size-modal-body { padding: 18px; max-height: 80vh; overflow-y: auto; }\n  .body-size-table { width: 100%; border-collapse: collapse; font-size: 1.4rem; }\n  .body-size-table th, .body-size-table td { border: 1px solid #ddd; padding: 8px 12px; text-align: center; }\n  .body-size-table thead { background: #FCD116; color: #1A1A1A; font-weight: 700; }\n  .body-size-table tbody tr:nth-child(even) { background: #f9f9f9; }\n  @media (max-width: 480px) { .size-modal-content { margin: 18% auto; width: 95%; } }\n</style>\n\n<script>\n  (function() {\n    var modal = document.getElementById('sizeGuideModalBody');\n    var btn = document.getElementById('openSizeGuideBody');\n    var closeBtn = document.getElementById('closeSizeGuideBody');\n    if (!modal || !btn) return;\n    btn.onclick = function() { modal.style.display = 'block'; modal.setAttribute('aria-hidden','false'); document.body.style.overflow='hidden'; };\n    closeBtn.onclick = function() { modal.style.display = 'none'; modal.setAttribute('aria-hidden','true'); document.body.style.overflow='auto'; };\n    window.addEventListener('click', function(e) { if (e.target === modal) { modal.style.display='none'; modal.setAttribute('aria-hidden','true'); document.body.style.overflow='auto'; } });\n  })();\n</script>"
