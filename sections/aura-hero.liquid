{{ 'aura-home.css' | asset_url | stylesheet_tag }}

<div class="aura-hero{% if section.settings.image %} aura-hero--has-image{% endif %}"
  {% if section.settings.image %}
    style="background-image: url('{{ section.settings.image | image_url: width: 2000 }}');"
  {% endif %}
>
  <div class="aura-hero__overlay" style="background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

  <div class="aura-hero__inner page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="aura-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    <h1 class="aura-hero__title">{{ section.settings.heading }}</h1>

    {%- if section.settings.subheading != blank -%}
      <p class="aura-hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="aura-hero__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="aura-hero__btn aura-hero__btn--primary">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.button2_label != blank -%}
        <a href="{{ section.settings.button2_link }}" class="aura-hero__btn aura-hero__btn--secondary">
          {{ section.settings.button2_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="aura-hero__trust">
      <span>⭐ +360 Clientes Satisfechos</span>
      <span>🚚 Envío Gratis</span>
      <span>💳 Pago Contra Entrega</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Principal",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 55,
      "label": "Oscuridad del overlay (%)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto superior",
      "default": "Calzado Premium · Top Quality 1.1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título principal",
      "default": "Estilo que habla por ti"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Calzado exclusivo con envío gratis a todo Colombia"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Botón 1 - texto",
      "default": "Ver Colección"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Botón 1 - enlace"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Botón 2 - texto"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Botón 2 - enlace"
    }
  ],
  "presets": [
    {
      "name": "Hero Principal"
    }
  ]
}
{% endschema %}
